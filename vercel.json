{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "vedara.eu"
        }
      ],
      "destination": "https://www.vedara.eu/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/ops",
      "destination": "/ops.html"
    },
    {
      "source": "/",
      "destination": "/web.html"
    }
  ]
}
